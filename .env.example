# ============================================
# 企業微信客服配置（必填）
# ============================================

# 企業 ID（我的企業頁面獲取）
WECOM_CORP_ID=ww9f72e51ed2bf6492

# 微信客服應用 Secret（應用管理頁面獲取）
WECOM_CS_SECRET=your_cs_secret_here

# 回調配置 Token（隨機生成，後台配置時填寫）
WECOM_TOKEN=your_random_token_here

# EncodingAESKey（後台自動生成，43字符）
WECOM_ENCODING_AES_KEY=your_encoding_aes_key_here

# ============================================
# 服務配置
# ============================================

# 服務端口（Zeabur 自動設置）
PORT=8000
HOST=0.0.0.0

# 數據目錄
WXAGENT_DATA_DIR=./data

# Cron 觸發密鑰（用於 /api/cron?secret=xxx）
CRON_SECRET=your_cron_secret_here

# ============================================
# 可選：企業微信群機器人（內部群使用）
# ============================================

# 群機器人 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ============================================
# 可選：推送配置
# ============================================

# 推送時間（星期幾 + 時間）
WXAGENT_PUSH_DAY=mon
WXAGENT_PUSH_HOUR=9
WXAGENT_PUSH_MINUTE=0

# DSEDJ API 基礎 URL
API_BASE_URL=https://portal.dsedj.gov.mo
