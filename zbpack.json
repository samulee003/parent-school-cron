{
  "schema_version": "1.0",
  "name": "家長學堂 WhatsApp Bot",
  "description": "自動抓取澳門家長學堂課程，透過 WhatsApp 回覆家長查詢",
  "icon": "📚",
  "templates": ["Dockerfile"],
  "port": 8000,
  "env": {
    "WHATSAPP_PHONE_NUMBER_ID": {
      "description": "WhatsApp Phone Number ID",
      "required": true,
      "type": "string"
    },
    "WHATSAPP_ACCESS_TOKEN": {
      "description": "WhatsApp Permanent Access Token",
      "required": true,
      "type": "password"
    },
    "WHATSAPP_VERIFY_TOKEN": {
      "description": "Meta Webhook Verify Token",
      "required": true,
      "type": "password"
    },
    "WHATSAPP_APP_SECRET": {
      "description": "Meta App Secret",
      "required": true,
      "type": "password"
    },
    "WHATSAPP_ALLOW_UNSIGNED_WEBHOOK": {
      "description": "Temporary compatibility switch for unsigned WhatsApp webhooks; keep false after Meta App Secret is configured",
      "required": false,
      "type": "string"
    },
    "CRON_SECRET": {
      "description": "Cron endpoint secret",
      "required": true,
      "type": "password"
    },
    "ADMIN_SECRET": {
      "description": "Admin endpoint secret",
      "required": true,
      "type": "password"
    }
  },
  "cron": {
    "description": "Optional weekly course refresh",
    "schedule": "0 1 * * 1",
    "endpoint": "/api/cron?secret=${CRON_SECRET}"
  }
}
