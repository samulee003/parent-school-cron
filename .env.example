# WhatsApp-first configuration

# Service
PORT=8000
HOST=0.0.0.0
WXAGENT_DATA_DIR=./data
WXAGENT_LOG_LEVEL=INFO
API_BASE_URL=https://portal.dsedj.gov.mo

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_VERIFY_TOKEN=generate_a_random_verify_token_here

# Recommended: Meta App Secret used to verify X-Hub-Signature-256
WHATSAPP_APP_SECRET=your_meta_app_secret_here

# Protected admin / cron endpoints
CRON_SECRET=generate_a_random_cron_secret_here
ADMIN_SECRET=generate_a_random_admin_secret_here

# Weekly cron defaults
WXAGENT_PUSH_DAY=mon
WXAGENT_PUSH_HOUR=9
WXAGENT_PUSH_MINUTE=0

# Optional legacy channels. Leave empty for WhatsApp-first MVP.
WECOM_WEBHOOK_URL=
WECOM_CORP_ID=
WECOM_CS_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
