{
  "name": "parent-school-cron",
  "description": "家長學堂 WhatsApp 課程查詢 Bot",
  "type": "python",
  "main": "src/api_server.py",
  "env": [
    {
      "key": "WHATSAPP_PHONE_NUMBER_ID",
      "description": "WhatsApp Phone Number ID",
      "required": true
    },
    {
      "key": "WHATSAPP_ACCESS_TOKEN",
      "description": "WhatsApp Permanent Access Token",
      "required": true
    },
    {
      "key": "WHATSAPP_VERIFY_TOKEN",
      "description": "Meta Webhook Verify Token",
      "required": true
    },
    {
      "key": "WHATSAPP_APP_SECRET",
      "description": "Meta App Secret for webhook signature verification",
      "required": true
    },
    {
      "key": "WHATSAPP_PROACTIVE_TEMPLATE_NAME",
      "description": "Approved WhatsApp template name for proactive messages outside the 24-hour window",
      "required": false
    },
    {
      "key": "WHATSAPP_PROACTIVE_TEMPLATE_LANGUAGE",
      "description": "WhatsApp proactive template language code, for example zh_HK",
      "required": false
    },
    {
      "key": "CRON_SECRET",
      "description": "Cron endpoint secret",
      "required": true
    },
    {
      "key": "ADMIN_SECRET",
      "description": "Admin endpoint secret",
      "required": true
    }
  ]
}
